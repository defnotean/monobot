DISCORD_TOKEN=your_discord_bot_token
LASTFM_API_KEY=your_lastfm_api_key
CLIENT_ID=your_discord_client_id
GEMINI_API_KEY=your_gemini_api_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
KLIPY_API_KEY=your_klipy_api_key
BOT_OWNER_ID=your_discord_user_id

# Stable identifier for personality/longmemory/audit rows in Supabase. Changing
# this creates a fresh personality — leave it alone unless you know why.
BOT_NAME=eris

# Kill switch for owner-only PC-agent tools (terminal, local exec, file browse,
# launch_app, system_info, list_processes). Set to 1 to disable without redeploy.
PC_AGENT_DISABLED=0

# Twin API — shared HMAC secret used to sign Eris→Irene command relay requests.
# Must match TWIN_API_SECRET on the Irene side. Generate with: openssl rand -hex 32
TWIN_API_SECRET=
IRENE_API_URL=https://irene-bot.onrender.com

# Gmail integration (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# GitHub (auto-detected from gh CLI if not set)
# GITHUB_TOKEN=your_github_pat

# Deploy monitoring (optional)
RENDER_API_KEY=your_render_api_key

# Background features (optional)
DREAM_CHANNEL_ID=channel_id_for_irene_random_thoughts
BRIEFING_CHANNEL_ID=channel_id_for_daily_briefings
