DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_USER_ID=your_discord_user_id_here
PORT=3001

# Stable identifier for personality/longmemory rows in Supabase. Changing this
# creates a fresh personality — leave it alone unless you know why.
BOT_NAME=irene

# Twin API — shared HMAC secret used to verify signed requests from Eris.
# Must match TWIN_API_SECRET on the Eris side. Generate with: openssl rand -hex 32
TWIN_API_SECRET=
