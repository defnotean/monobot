# ─────────────────────────────────────────────────────────────────────────────
# Irene — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you actually need.
# Most vars have sensible defaults baked into config.js — the .env only needs
# the ones marked Required, plus whichever optional integrations you want on.
# Comments and blank lines are ignored. Quotes around values are stripped.
# ─────────────────────────────────────────────────────────────────────────────


# ═══ DISCORD ═════════════════════════════════════════════════════════════════
# Core Discord identity. Without these the bot can't log in or recognize you.

# Bot login token from the Discord Developer Portal. NEVER commit this.
# Required: yes. Where to get it: discord.com/developers/applications → your app → Bot → Reset Token.
DISCORD_BOT_TOKEN=your-bot-token-here

# Application ID — used for slash command registration and OAuth invite links.
# Required: yes (fatal at startup).
# Where to get it: discord.com/developers/applications → your app → General Information → Application ID.
DISCORD_CLIENT_ID=

# Discord user ID of the bot owner (the "boss"). Drives owner-only commands,
# firewall bypass, and personality references.
# Required: YES for owner tools. There is NO code default — if unset (or not
# a valid 17-20 digit Discord ID) the bot still boots, but logs a [SECURITY]
# warning and every owner-only command/tool fails closed.
# Where to get it: enable Developer Mode in Discord → right-click your name → Copy User ID.
DISCORD_USER_ID=

# HTTP server port for the keepalive / twin / presence endpoints.
# Required: no. Default: 3001. Render/Heroku-style hosts inject their own PORT.
PORT=3001

# Stable identifier used for personality, longmemory, and audit rows in Supabase.
# Changing this creates a fresh personality from scratch — leave alone unless you mean it.
# Required: no. Default: irene.
BOT_NAME=irene


# ═══ AI PROVIDERS ════════════════════════════════════════════════════════════
# Irene runs primarily on Gemini. NVIDIA + Voyage are optional add-ons.

# Selects which provider implementation in ai/providers/ to use. Defaults to
# "gemini". Also supports "nvidia" and OpenAI-compatible aliases:
# openai-compatible, openai, openrouter, groq, cerebras, mistral, deepinfra,
# together, github, cloudflare, lmstudio, ollama.
# Required: no. Default: gemini.
AI_PROVIDER=gemini

# ─── Gemini (primary brain) ───────────────────────────────────────────────────
# Up to 12 keys are rotated through to dodge per-key quota limits. Fill in as
# many as you have — extras are silently dropped via .filter(Boolean).
# Required: yes (at least GEMINI_API_KEY). Where to get keys: aistudio.google.com → Get API key.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_API_KEY_11=
GEMINI_API_KEY_12=

# Gemini model selection. Override only if you want a different tier.
# Required: no. Defaults shown.
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-3-flash-preview

# ─── NVIDIA (optional alt provider — Kimi / Llama hosted) ────────────────────
# Only needed if you set AI_PROVIDER=kimi or AI_PROVIDER=nvidia above.
# Required: conditional (yes if using NVIDIA backend, otherwise no).
# Where to get it: build.nvidia.com → sign in → API key.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.6
NVIDIA_FAST_MODEL=moonshotai/kimi-k2.6
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=1.0
NVIDIA_THINKING=true
NVIDIA_TOOL_STRICTNESS=balanced

# --- OpenAI-compatible providers (optional alt brain) ----------------------
# Used when AI_PROVIDER is one of:
# openai-compatible/openai/openrouter/groq/cerebras/mistral/deepinfra/together/
# github/cloudflare/lmstudio/ollama.
# Required: conditional (yes for hosted providers; not needed for local
# LM Studio/Ollama if your server does not require auth).
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_MODEL=openrouter/owl-alpha
OPENAI_COMPAT_FAST_MODEL=openrouter/owl-alpha
OPENAI_COMPAT_MAX_TOKENS=8192
OPENAI_COMPAT_TEMPERATURE=0.9
OPENAI_COMPAT_TOP_P=1.0
OPENAI_COMPAT_PROVIDER_NAME=
OPENAI_COMPAT_HTTP_REFERER=
OPENAI_COMPAT_APP_TITLE=Irene
OPENAI_COMPAT_EXTRA_HEADERS={}
OPENAI_COMPAT_TOOL_CHOICE=none
OPENAI_COMPAT_ALLOW_NO_API_KEY=0
OPENAI_COMPAT_API_KEYS=

# Cap on tool-calling loop iterations per AI turn. Defaults: 6 when
# AI_PROVIDER is local (lmstudio/ollama), 12 otherwise.
OPENAI_COMPAT_MAX_ITERATIONS=

# Optional JSON object merged into every /chat/completions request body —
# lets backend-specific options through the OpenAI-shaped endpoint. Invalid
# JSON logs a warning and is ignored (treated as unset). Example for Ollama
# (32k context, thinking off): {"options":{"num_ctx":32768,"think":false}}
OPENAI_COMPAT_EXTRA_BODY=

# Inject the tool-coaching block into the compat-lane system prompt.
# "1"/"true" or "0"/"false". Default: true for local providers
# (lmstudio/ollama), false for hosted ones.
OPENAI_COMPAT_TOOL_COACHING=

# Provider-specific key aliases also work, so switching AI_PROVIDER does not
# require renaming secrets.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
DEEPINFRA_API_KEY=
TOGETHER_API_KEY=
GITHUB_MODELS_API_KEY=
CLOUDFLARE_API_TOKEN=

# ─── Voyage (embeddings for semantic memory recall) ──────────────────────────
# Without this, vector-based long-term memory falls back to keyword search.
# Required: no (recommended for full memory features).
# Where to get it: voyageai.com → Dashboard → API Keys.
VOYAGE_API_KEY=

# Local Ollama integrations. Optional, but recommended for self-hosted image
# understanding because raw Discord image bytes stay on your machine.
# Pull examples:
#   ollama pull nomic-embed-text
#   ollama pull qwen2.5vl:7b
OLLAMA_EMBED_URL=
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_URL=
OLLAMA_VISION_MODEL=qwen2.5vl:7b
LOCAL_VISION_MAX_IMAGES=4
LOCAL_VISION_IMAGE_MAX_BYTES=12582912
LOCAL_VISION_MAX_TILES=4
LOCAL_VISION_TILE_MIN_LONG_EDGE=1600
LOCAL_VISION_TILE_MIN_ASPECT=1.45
LOCAL_VISION_TILE_OVERLAP_RATIO=0.12
LOCAL_VISION_DETAIL_MAX_CHARS=3600


# ═══ PERSISTENCE (Supabase) ══════════════════════════════════════════════════
# Backing store for personality, long-term memory, audit logs, twin state.

# Supabase project URL (https://<project-ref>.supabase.co).
# Strongly recommended — Irene boots without it but loses ALL moderation state,
# custom commands, ticket configs, reminders, giveaways, settings on every
# restart. Set REQUIRE_PERSISTENCE=1 below to make missing DB a fatal error.
# Where to get it: supabase.com → Project Settings → API → Project URL.
# Self-hosting? See docs/self-hosting.md for plain-Postgres / Docker-Supabase / no-DB setups.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase API key used by Irene persistence. SUPABASE_KEY is required for the
# persistence gate; SUPABASE_ANON_KEY below is parsed but does not enable
# persistence by itself.
# Required: yes. Where to get it: supabase.com → Project Settings → API → Project API keys.
SUPABASE_KEY=your-supabase-key-here

# Optional compatibility alias. Do not rely on this without SUPABASE_KEY.
# Required: no.
SUPABASE_ANON_KEY=

# Fail startup instead of falling back to in-memory storage when Supabase is
# unavailable. Keep false/0 for local/dev; production deploys should use 1.
REQUIRE_PERSISTENCE=0

# Phase 1 of the persistence refactor — when true, every write goes to BOTH
# the legacy single-row blob (bot_data) AND the new per-entity tables defined
# in packages/irene/migrations/. Reads still come from the legacy path; this
# flag exists to validate the new layer in production before later PRs migrate
# read paths over and drop the old blob.
# Required: no. Default: false. Apply the migration first before enabling.
DUAL_WRITE_PERSISTENCE=false


# ═══ MUSIC / VOICE (Lavalink) ════════════════════════════════════════════════
# Required only if you want music playback. The bot boots fine without it;
# music commands will simply fail until a Lavalink node is reachable.

# Lavalink node hostname.
# Required: conditional (yes for music, no otherwise). Default: localhost.
# Where to get it: self-hosted (https://lavalink.dev/getting-started/index.html)
# or use a public node from lavalink-list.
LAVALINK_HOST=localhost

# Lavalink node port.
# Required: no. Default: 2333.
LAVALINK_PORT=2333

# Shared Lavalink password (must match the node's application.yml).
# Required: YES for any non-localhost LAVALINK_HOST. The Lavalink default
# password "youshallnotpass" is a well-known string shared by every default
# Lavalink install — leaving it as-is on a publicly reachable port is
# equivalent to no auth at all. If LAVALINK_PASSWORD is unset OR equals
# "youshallnotpass" AND LAVALINK_HOST is not localhost, music features will
# refuse to start at boot. Generate a strong value, e.g.:
#   openssl rand -hex 32
# Localhost-only deploys (LAVALINK_HOST=localhost / 127.0.0.1) will accept
# the default with a softer warning, since the port isn't reachable off-host.
LAVALINK_PASSWORD=

# Use wss:// + https:// instead of ws:// + http:// when talking to the node.
# Required: no. Default: false. Set to "true" for TLS-fronted Lavalink.
LAVALINK_SECURE=false

# ─── Voice wake-word STT cost guards (Irene voice listener) ──────────────────
# These bound how much speech-to-text the wake-word listener will run, so a
# busy or hostile VC can't drain the STT budget. Both apply only while a voice
# session is active.
# NOTE: a value of 0 or any non-positive/garbage value SILENTLY falls back to
# the default below — it does NOT mean "unlimited" or "off". To disable voice
# listening entirely, don't start a session.

# Rolling per-guild cap on STT transcriptions per minute.
# Required: no. Default: 20.
VOICE_STT_BUDGET_PER_MIN=20

# Hard cap on total STT transcriptions for a single listener session
# (a session is already capped at 60 minutes).
# Required: no. Default: 200.
VOICE_STT_BUDGET_PER_SESSION=200


# ═══ EXTERNAL SERVICES ═══════════════════════════════════════════════════════
# Optional integrations. Each one degrades gracefully when missing.

# ─── Twitch (live-stream notifications) ──────────────────────────────────────
# Required: no (disable Twitch features if absent).
# Where to get them: dev.twitch.tv → Console → Apps → Register Your Application.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Brave Search / Answers (web_search tool). Answers returns a concise grounded
# answer first; Search returns result snippets and source URLs.
# Required: no. Where to get them: api-dashboard.search.brave.com.
BRAVE_SEARCH_API_KEY=
BRAVE_ANSWERS_API_KEY=
BRAVE_ANSWERS_MODEL=brave
BRAVE_ANSWERS_TIMEOUT_MS=5000
BRAVE_SEARCH_TIMEOUT_MS=3500
WEB_SEARCH_BACKEND_TIMEOUT_MS=5000
WEB_SEARCH_DDG_TIMEOUT_MS=5000

# Force on/off the Tier-1 Gemini Google Search grounding path used by the
# web_search tool. Truthy values ("1", "true", "yes", "on") always try the
# Gemini grounded-answer call before falling through to Brave/Tavily/DDG.
# Falsy values ("0", "false", "no", "off") always skip it. Leave unset to
# auto-enable only when AI_PROVIDER is "gemini" or "google".
# Required: no. Default: auto (based on AI_PROVIDER).
WEB_SEARCH_GEMINI_GROUNDING=

# Optional alternate web_search backends.
SEARXNG_QUERY_URL=
TAVILY_API_KEY=
SERPER_API_KEY=

# ─── Google Programmable Search (web_search tool) ────────────────────────────
# Optional Google fallback for the AI's web search tool.
# Required: no.
# Where to get them: console.cloud.google.com → APIs → Custom Search API + programmablesearchengine.google.com.
GOOGLE_SEARCH_KEY=
GOOGLE_SEARCH_CX=

# ─── Klipy (GIF search for send_gif tool) ────────────────────────────────────
# Required: no (the send_gif tool is unavailable without it).
# Where to get it: klipy.com → developer dashboard.
KLIPY_API_KEY=


# ═══ TWIN COORDINATION (Eris ↔ Irene) ════════════════════════════════════════
# HMAC-signed channel for the twin sister bot to send commands & sync state.

# Shared secret used to sign /api/twin/command requests and gate /api/twin/state.
# MUST match TWIN_API_SECRET on the Eris side or every twin call will 401.
# Required: yes (twin features won't work without it; bot still boots).
# Generate with: openssl rand -hex 32
TWIN_API_SECRET=

# Base URL for the Eris twin's API (where Irene sends outbound twin commands).
# Required: only if you want Irene-to-Eris twin features. Set to the public URL
# of your Eris deployment (e.g. a Render URL, or your tunnel/reverse-proxy host).
ERIS_API_URL=

# Discord bot ID of the Eris twin — used for mention routing, "is this msg
# from my sister?" checks in messageCreate, and {{TWIN_BOT_ID}} substitution
# in the personality / relationships prompt. Naming asymmetry note: Irene
# refers to its twin explicitly as ERIS_BOT_ID while Eris refers to its twin
# as TWIN_BOT_ID — each bot names the specific sibling it talks to. If unset,
# twin-mention detection and the bot-ID reference in prompts go blank, but
# the bot still boots.
# Required: no (twin features degrade silently if absent).
# Where to get it: enable Developer Mode in Discord → right-click the Eris
# bot user → Copy User ID. Or pull it from the deployed Eris bot's profile.
ERIS_BOT_ID=


# ═══ DEPLOYMENT / KEEPALIVE ══════════════════════════════════════════════════
# Public-facing URL of this bot, used for self-ping keepalive and CORS.

# Public URL of this Irene deployment. RENDER_EXTERNAL_URL is auto-injected by
# Render; EXTERNAL_URL is a manual override for other hosts.
# Required: no (only needed for self-ping keepalive and live-stream callbacks).
EXTERNAL_URL=
RENDER_EXTERNAL_URL=

# Origin allowed to hit the dashboard endpoints, plus an optional API key.
# Required: no (only needed if you're running the optional web dashboard).
DASHBOARD_URL=
DASHBOARD_API_KEY=
# Localhost API auth bypass is off by default. Only set to 1 on a trusted
# single-user machine where local browser tabs and SSH tunnels are acceptable.
DASHBOARD_ALLOW_LOCALHOST_BYPASS=0


# ═══ TUNABLES ════════════════════════════════════════════════════════════════
# Override hard-coded defaults in config.js. All values are milliseconds.
# Defaults shown — uncomment any you want to override.

# Quick acknowledgement reply (typing indicator, "thinking" embeds).
# Required: no. Default: 5000.
TIMEOUT_QUICK_REPLY=5000

# Fast-path AI worker timeout (cheap models, simple intents).
# Required: no. Default: 35000.
TIMEOUT_WORKER_FAST=35000

# Slow-path AI worker timeout (full reasoning loop).
# Required: no. Default: 60000.
TIMEOUT_WORKER_SLOW=60000

# Tool execution timeouts by tier (fast lookups → very slow scrapes).
# Required: no. Defaults: 15000 / 30000 / 60000.
TIMEOUT_TOOL_FAST=15000
TIMEOUT_TOOL_SLOW=30000
TIMEOUT_TOOL_VERY_SLOW=60000

# Outer wall-clock deadline (ms) for one full AI turn — all model iterations
# plus tool executions. Backstop so a looping model can't wedge a channel.
# Required: no. Default: 180000.
TIMEOUT_TURN_DEADLINE=

# Cap on tier-1 tool schemas sent per message. Default: 32. For local 14B
# models, 16-20 keeps the schema payload in the range where mid-size models
# stay reliable.
# Required: no.
TOOLS_TIER1_MAX=

# Shadow-log what a lower tier-1 tool cap would have dropped, without any
# behavior change. Set to 1 to enable.
# Required: no. Default: off.
TOOLS_SHADOW_LOG=

# Generic outbound HTTP fetch timeout (search results, embed previews, etc).
# Required: no. Default: 5000.
TIMEOUT_FETCH=5000

# Extra non-default destination ports allowed by safeFetch for user/model URLs.
# Defaults allow only omitted/80/443. Private, loopback, link-local, and
# metadata IPs stay blocked even when a port is listed.
# Example: SAFE_FETCH_EXTRA_PORTS=8080,11434
# Required: no.
SAFE_FETCH_EXTRA_PORTS=

# Disable ANSI color codes in console output (useful for log aggregators).
# Required: no. Set to any non-empty value to disable colors.
NO_COLOR=


# ─────────────────────────────────────────────────────────────────────────────
# MINIMUM VIABLE LOCAL DEV
# ─────────────────────────────────────────────────────────────────────────────
# To get the bot booted with moderation + chat + memory working:
#
#   DISCORD_BOT_TOKEN     — required, bot will exit on startup without it
#   DISCORD_CLIENT_ID     — required for slash commands to register correctly
#   DISCORD_USER_ID       — required so owner-only commands recognize you
#                           (no default: unset logs a [SECURITY] warning and
#                           disables all owner-only commands/tools)
#   GEMINI_API_KEY        — required for the AI brain to respond at all
#   SUPABASE_URL          — required for personality/memory persistence
#   SUPABASE_KEY          — required, paired with SUPABASE_URL
#   TWIN_API_SECRET       — required if you want twin coordination (else skip)
#
# Music features are OPTIONAL — leave Lavalink vars at defaults (or unset) and
# the bot still runs; only /play and friends will fail. Moderation, chat, and
# memory are core and need the above seven vars.
#
# Twitch / Google Search / Klipy / Voyage are nice-to-haves; the bot degrades
# gracefully when they're missing (the related tools just refuse to fire).
# ─────────────────────────────────────────────────────────────────────────────
