{
  "name": "@defnotean/irene",
  "version": "2.2.0",
  "type": "module",
  "description": "Irene — Discord AI bot with moderation, server setup, AI chat, games, music, and presence API. Twin of Eris.",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "deploy": "node deploy-commands.js",
    "build": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@defnotean/shared": "*",
    "@discordjs/voice": "^0.18.0",
    "@google/genai": "1.50.1",
    "@supabase/supabase-js": "2.104.1",
    "cheerio": "^1.2.0",
    "discord.js": "14.26.3",
    "prism-media": "^1.3.5",
    "rss-parser": "^3.13.0",
    "shoukaku": "^4.3.0",
    "spotify-uri": "^4.1.0",
    "spotify-url-info": "^3.3.0",
    "voyageai": "0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
