# ─────────────────────────────────────────────────────────────────────────────
# Eris — environment variables
# Copy this file to `.env` and fill in the values you need. Vars are loaded
# by config.js at startup; missing critical vars will fail-fast with a
# console error. See "MINIMUM VIABLE LOCAL DEV" at the bottom of this file
# for the smallest set required to actually boot the bot.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token used to authenticate the gateway connection.
# Required: yes (fatal at startup). Where to get it: discord.com/developers/applications → your app → Bot → Reset Token.
DISCORD_TOKEN=

# Application (client) ID — used to register slash commands.
# Required: yes (fatal at startup). Where to get it: discord.com/developers/applications → your app → General Information → Application ID.
CLIENT_ID=

# Discord user ID of the bot owner. Owner gets PC-agent / system tools and
# is the only user the bot calls "boss". Default points at the original owner —
# CHANGE THIS to your own user ID for a fresh install.
# Required: no (defaults to original owner ID). Where to get it: Discord → User Settings → Advanced → Developer Mode, then right-click yourself → Copy User ID.
BOT_OWNER_ID=

# HTTP port for the dashboard / health-check API.
# Required: no (defaults to 3000).
PORT=3000

# Stable identifier used for personality / longmemory / audit rows in Supabase.
# Changing this creates a fresh personality — leave it alone unless you know why.
# Required: no (defaults to "eris").
BOT_NAME=eris


# ─── AI providers ────────────────────────────────────────────────────────────
# Selects which provider implementation in ai/providers/ to use. Defaults to
# "gemini". Also supports OpenAI-compatible aliases: openai-compatible,
# openai, openrouter, groq, cerebras, mistral, deepinfra, together, github,
# cloudflare, lmstudio, ollama.
# Required: no. Default: gemini.
AI_PROVIDER=gemini

# At least one Gemini key is REQUIRED at startup when AI_PROVIDER=gemini.
# Extra keys 2-4 are rotated through for rate-limit smoothing.
# Required: conditional (fatal if AI_PROVIDER=gemini). Where to get it: aistudio.google.com → Get API key.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Override Gemini model IDs. Defaults are tuned for the live deployment;
# only set these if you want to pin a specific model version.
# Required: no.
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=
GEMINI_FAST_MODEL=

# NVIDIA NIM API — alternate provider. Set AI_PROVIDER=kimi for Kimi K2.6
# defaults, or AI_PROVIDER=nvidia with explicit model overrides.
# Required: conditional (fatal only if AI_PROVIDER=nvidia/kimi). Where to get it: build.nvidia.com → your profile → API Keys.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.6
NVIDIA_FAST_MODEL=moonshotai/kimi-k2.6
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=1.0
NVIDIA_THINKING=true
NVIDIA_TOOL_STRICTNESS=balanced

# Generic OpenAI-compatible /chat/completions API. Set AI_PROVIDER to any of
# the aliases listed above. Provider-specific defaults are picked from
# AI_PROVIDER, but every value can be overridden here.
# Required: conditional (fatal only for OpenAI-compatible AI_PROVIDER values).
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_API_KEYS=
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_MODEL=openrouter/owl-alpha
OPENAI_COMPAT_FAST_MODEL=openrouter/owl-alpha
OPENAI_COMPAT_MAX_TOKENS=8192
OPENAI_COMPAT_TEMPERATURE=0.9
OPENAI_COMPAT_TOP_P=1.0
OPENAI_COMPAT_PROVIDER_NAME=
OPENAI_COMPAT_HTTP_REFERER=
OPENAI_COMPAT_APP_TITLE=
OPENAI_COMPAT_EXTRA_HEADERS=
OPENAI_COMPAT_TOOL_CHOICE=none
OPENAI_COMPAT_ALLOW_NO_API_KEY=0

# Provider-specific key aliases also work, so switching AI_PROVIDER does not
# require renaming secrets.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
DEEPINFRA_API_KEY=
TOGETHER_API_KEY=
GITHUB_MODELS_API_KEY=
CLOUDFLARE_API_TOKEN=

# Voyage AI embeddings — used for semantic memory recall.
# Without this, semantic memory search degrades to keyword-only fallback.
# Required: no (recommended). Where to get it: voyageai.com → API Keys.
VOYAGE_API_KEY=


# ─── Persistence (Supabase) ──────────────────────────────────────────────────
# Postgres-backed storage for coins, memories, settings, mood, relationships,
# audit logs. Without these the bot still boots but logs a [WARN] and runs
# fully ephemeral — nothing is saved between restarts.
# Required: no (strongly recommended — most features become useless without it). Where to get them: supabase.com → your project → Project Settings → API.
SUPABASE_URL=
SUPABASE_KEY=

# Fail startup instead of falling back to in-memory storage when Supabase is
# unavailable. Keep 0 for local/dev; production deploys should use 1.
REQUIRE_PERSISTENCE=0


# ─── External services ───────────────────────────────────────────────────────
# Last.fm API key — powers /fm commands (now playing, top artists, etc.).
# Without it, /fm commands fail with a [WARN] at startup.
# Required: no. Where to get it: last.fm/api/account/create.
LASTFM_API_KEY=

# Klipy GIF API key — used by send_gif tool for reaction GIFs.
# Required: no (gif tool will fail silently if absent). Where to get it: klipy.com → API.
KLIPY_API_KEY=

# Render deploy monitoring — lets check_deploy / read deploy logs work.
# Required: no. Where to get it: dashboard.render.com → Account Settings → API Keys.
RENDER_API_KEY=

# GitHub personal access token — backs github_repos / github_issues / github_prs
# tools. Runtime config no longer shells out to the GitHub CLI; set this
# explicitly when those tools should work.
# Required: no. Where to get it: github.com → Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=

# Google OAuth credentials for Gmail integration (read_emails tool). All three
# are needed — partial config disables the integration silently.
# Required: no (all 3 needed together). Where to get them: console.cloud.google.com → APIs & Services → Credentials. Refresh token via OAuth playground.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=


# ─── Twin coordination (Eris ↔ Irene) ────────────────────────────────────────
# Shared HMAC secret used to sign Eris→Irene command relay requests.
# MUST match TWIN_API_SECRET on the Irene side or all twin calls 401.
# Generate with: openssl rand -hex 32
# Required: no (only if you actually run the twin pair). Where to get it: generate locally, then set the same value on both bots.
TWIN_API_SECRET=

# Base URL of the Irene bot's HTTP API. Default points at the deployed Irene
# instance; override for local twin development.
# Required: no (defaults to deployed Irene URL).
IRENE_API_URL=


# ─── Channel IDs ─────────────────────────────────────────────────────────────
# Channel where Eris posts random "dream"-style background thoughts.
# Required: no (feature disabled if absent). Where to get it: right-click the channel in Discord → Copy Channel ID.
DREAM_CHANNEL_ID=

# Channel where Eris posts daily briefings.
# Required: no (feature disabled if absent). Where to get it: right-click the channel in Discord → Copy Channel ID.
BRIEFING_CHANNEL_ID=


# ─── Dashboard API (HTTP server) ─────────────────────────────────────────────
# Auth token for the /api/* dashboard endpoints. If unset, only TWIN_API_SECRET
# is accepted; setting this lets you give the dashboard a separate credential
# from the twin secret.
# Required: no. Where to get it: generate locally with: openssl rand -hex 32.
DASHBOARD_API_KEY=

# Extra origin allowed by the dashboard CORS policy (in addition to the
# hardcoded monobot / dashboard hosts and RENDER_EXTERNAL_URL).
# Required: no. Where to get it: set to whatever URL serves your dashboard frontend.
DASHBOARD_URL=

# Public URL of this Render service. Auto-set by Render at runtime — do NOT
# set manually unless you're emulating Render locally for CORS testing.
# Required: no (Render sets it automatically in production).
RENDER_EXTERNAL_URL=


# ─── Safety / kill switches ──────────────────────────────────────────────────
# Kill switch for owner-only PC-agent tools (terminal, local exec, file browse,
# launch_app, system_info, list_processes). Set to 1 to disable without redeploy.
# Required: no (defaults to "0" = enabled).
PC_AGENT_DISABLED=0


# ─── Tunables / timeouts (override only if you know why) ─────────────────────
# Timeout (ms) for the "quick reply" path — short single-shot replies that
# bypass the worker. Defaults to 15000.
# Required: no.
TIMEOUT_QUICK_REPLY=

# Timeout (ms) for the worker thread that runs the full tool-calling loop.
# Defaults to 60000.
# Required: no.
TIMEOUT_WORKER=

# Timeout (ms) for outbound fetches (web_search, scrape_url, image fetches).
# Defaults to 5000.
# Required: no.
TIMEOUT_FETCH=

# Disable ANSI color codes in console logs. Set to "1" or any truthy value to
# get plain text logs (useful when piping to a file or non-TTY collector).
# Required: no.
NO_COLOR=


# ─────────────────────────────────────────────────────────────────────────────
# MINIMUM VIABLE LOCAL DEV
# ─────────────────────────────────────────────────────────────────────────────
# To get the bot to actually start, you need exactly these three:
#   1. DISCORD_TOKEN       — bot will exit(1) without it
#   2. CLIENT_ID           — bot will exit(1) without it
#   3. GEMINI_API_KEY      — bot will exit(1) without it (default AI_PROVIDER is "gemini")
#
# That gets you a running bot with NO persistence — coins, memories, settings,
# mood, and relationships will all reset on every restart. For anything beyond
# "does it boot" you almost certainly also want:
#   4. SUPABASE_URL + SUPABASE_KEY — turns on the database. Without this the
#      bot logs a [WARN] and runs fully in-memory.
#   5. BOT_OWNER_ID                — set to YOUR Discord user ID so owner-only
#      tools recognize you (otherwise they apply to the previous owner).
#
# Everything else is purely additive: each missing key just disables one
# feature (no Last.fm key → /fm fails; no Klipy key → gif tool fails; no
# Twin secret → ask_irene fails; etc.) — none of them block startup.
# ─────────────────────────────────────────────────────────────────────────────
